# ═══════════════════════════════════════════════════════════════
# MedAI Environment Variables (root)
# Copy this file to .env and fill in values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# Backend API URL — used by React frontend (VITE_ prefix required)
# For local dev:  http://localhost:8000
# For Docker:     leave empty — Nginx proxies /api to backend
VITE_API_URL=http://localhost:8000

# ── Google Sign-In (optional) ────────────────────────────────
# Create a project at https://console.cloud.google.com
# → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# Add your domain to "Authorized JavaScript origins"
VITE_GOOGLE_CLIENT_ID=

# ── Mobiquick / UPI Payments ─────────────────────────────────
# Your Mobiquick wallet UPI ID  (money goes directly to this)
# Mobiquick: 6303089945@mbk   |   PhonePe: 6303089945@ybl
VITE_UPI_ID=6303089945@mbk
# Name shown on QR code / payment confirmation screen
VITE_MERCHANT_NAME=R SAI PRASAD
# Your WhatsApp number for payment notifications — country code + number, no + or spaces
# India: 91 + 10-digit mobile = 916303089945
VITE_WHATSAPP_NO=916303089945

# ngrok Auth Token — enables public internet access via Docker
# Get yours free at: https://dashboard.ngrok.com/get-started/your-authtoken
# Leave blank to skip ngrok (app works locally at http://localhost)
NGROK_AUTHTOKEN=
