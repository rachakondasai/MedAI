# ═══════════════════════════════════════════════════════════════
# MedAI Environment Variables (root)
# Copy this file to .env and fill in values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# Backend API URL — used by React frontend (VITE_ prefix required)
# For local dev:  http://localhost:8000
# For Docker:     leave empty — Nginx proxies /api to backend
VITE_API_URL=http://localhost:8000

# ngrok Auth Token — enables public internet access via Docker
# Get yours free at: https://dashboard.ngrok.com/get-started/your-authtoken
# Leave blank to skip ngrok (app works locally at http://localhost)
NGROK_AUTHTOKEN=
