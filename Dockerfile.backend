# ─────────────────────────────────────────────────
# MedAI Backend — FastAPI + LangChain + RAG
# ─────────────────────────────────────────────────

FROM python:3.13-slim

# System deps for FAISS and PDF processing
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy requirements first (Docker layer caching)
COPY server/requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt

# Copy backend source code
COPY server/ .

# Create a directory for the SQLite database (persistent via volume)
RUN mkdir -p /data

# Environment variables (defaults — override via docker-compose or .env)
ENV PYTHONUNBUFFERED=1
ENV OPENAI_API_KEY=""
ENV MEDAI_DATA_DIR=/data

EXPOSE 8000

# Run with uvicorn — production mode (no reload)
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
