# OpenAI API Key — Leave blank here. Admin can add it via the Settings page in the dashboard.
# If you want the server to have a default key, paste it below:
OPENAI_API_KEY=

# JWT Secret — MUST be set and stable across server restarts.
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-jwt-secret-here
# Google OAuth Client ID — for "Sign in with Google" feature
# Get it from: https://console.cloud.google.com -> APIs & Services -> Credentials
# Leave blank to disable Google Sign-In
GOOGLE_CLIENT_ID=
